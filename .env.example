# ─────────────────────────────────────────────
# SonicAI — Environment Configuration
# Copy this file to backend/.env and fill in values
# ─────────────────────────────────────────────

# Database
# SQLite (default, no setup needed for local dev):
DATABASE_URL=sqlite+aiosqlite:///./sonicai.db
# PostgreSQL (for Docker / production):
# DATABASE_URL=postgresql+asyncpg://sonicai:sonicai_pass@db:5432/sonicai

# Security — CHANGE THIS before any public deployment
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Audio output directory (relative to backend/)
AUDIO_OUTPUT_DIR=./audio_files
